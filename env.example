# Copy to .env and fill in values. On Vercel: Project → Settings → Environment Variables

DATABASE_URL=
AUTH_SECRET=

# Public site URL used in emails (must be a full absolute URL for Gmail). Examples:
#   https://your-app.vercel.app
#   https://lms.yourschool.com
# You may omit https:// only for non-localhost hosts; the app will add https://. Localhost: use http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Resend (https://resend.com) — required for welcome emails in production
RESEND_API_KEY=
# After verifying your domain in Resend, e.g. "Intellee College <noreply@yourdomain.com>"
# If unset, sends from onboarding@resend.dev (testing only; limited recipients)
RESEND_FROM_EMAIL=

OPENAI_API_KEY=
