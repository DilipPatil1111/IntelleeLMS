# Copy to .env and fill in values. On Vercel: Project → Settings → Environment Variables

DATABASE_URL=
AUTH_SECRET=

# Public site URL (login links in emails). On Vercel you can omit if VERCEL_URL is set — the app falls back to https://VERCEL_URL
NEXT_PUBLIC_APP_URL=

# Resend (https://resend.com) — required for welcome emails in production
RESEND_API_KEY=
# After verifying your domain in Resend, e.g. "Intellee College <noreply@yourdomain.com>"
# If unset, sends from onboarding@resend.dev (testing only; limited recipients)
RESEND_FROM_EMAIL=

OPENAI_API_KEY=
