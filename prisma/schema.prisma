generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────

enum Role {
  STUDENT
  TEACHER
  PRINCIPAL
}

enum AssessmentType {
  QUIZ
  TEST
  ASSIGNMENT
  PROJECT
  HOMEWORK
}

enum AssessmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
  GRADED
}

enum QuestionType {
  MCQ
  SHORT
  PARAGRAPH
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum HolidayType {
  PUBLIC
  COLLEGE
  CUSTOM
  SUMMER_BREAK
  WINTER_BREAK
  EXAM_PREPARATION_LEAVE
}

/** Scheduled block on the program Full Calendar (teaching or lunch). */
enum ProgramCalendarSlotType {
  SESSION
  LUNCH
}

/** Session style for teaching blocks (Excel: theory / practical / slack / project). Lunch ignores this. */
enum ProgramSessionCategory {
  THEORY
  PRACTICAL
  SLACK
  PROJECT
}

enum NotificationType {
  ASSESSMENT_INVITE
  RESULT_PUBLISHED
  ATTENDANCE_REMINDER
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  ENROLLMENT_CONFIRMED
  GENERAL
  TEACHER_SELF_ATTENDANCE_REQUIRED
  ANNOUNCEMENT
  HOLIDAY_NOTICE
  ONBOARDING_STUDENT_COMPLETED
  ADMISSION_CANCELLED
  STUDENT_SUSPENDED
  COMPLIANCE_WARNING
  STUDENT_EXPELLED
  STUDENT_TRANSFERRED
  GRADUATION_CERTIFICATE_SENT
  FEEDBACK_REPLY
  /** Student’s attendance % fell below configured threshold. */
  LOW_ATTENDANCE_STUDENT
  /** Staff alert: a student’s attendance is below threshold. */
  LOW_ATTENDANCE_STAFF
  /** Teacher requests calendar/hours correction for a batch date. */
  CALENDAR_HOURS_UPDATE_REQUEST
}

/** Admission / enrollment lifecycle (principal may set Cancelled, Suspended, Expelled, Transferred). */
enum StudentStatus {
  APPLIED
  ACCEPTED
  ENROLLED
  /** Completed academic requirements for the current phase (e.g. year) — not yet final graduation. */
  COMPLETED
  /** All academic and compliance requirements met; graduation certificate issued. */
  GRADUATED
  /** Stopped for this intake; may rejoin in a future year. */
  RETAKE
  CANCELLED
  SUSPENDED
  EXPELLED
  TRANSFERRED
}

/** Recorded when status is SUSPENDED (fees, attendance, or academic non-compliance). */
enum SuspensionReason {
  FEES
  ATTENDANCE
  ACADEMIC
  OTHER
}

enum PolicyType {
  PROGRAM
  COLLEGE
  STUDENT
  OTHER
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  ENROLLED
}

enum ContentType {
  TEXT
  VIDEO
  AUDIO
  IMAGE
  DOCUMENT
  URL
  PRESENTATION
}

enum FeedbackCategory {
  PROGRAM_CONTENT
  TEACHING
  OTHER
  /** Teacher-only: observation or concern about a specific student. */
  STUDENT_CONCERN
}

enum FeedbackAuthorRole {
  STUDENT
  TEACHER
}

/** Lesson row under Program Chapter (syllabus / “Program Content”). */
enum ProgramLessonKind {
  TEXT
  VIDEO
  PDF
  AUDIO
  PRESENTATION
  QUIZ
  DOWNLOAD
  SURVEY
  MULTIMEDIA
}

// ─── Auth / Users ────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  firstName      String
  middleName     String?
  lastName       String
  role           Role      @default(STUDENT)
  image          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  visaStatus     String?
  profilePicture String?
  mustChangePassword Boolean @default(false)
  isActive       Boolean   @default(true)
  signatureImageUrl   String?
  signatureTypedName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  attempts             Attempt[]
  answers              Answer[]
  attendanceRecords    AttendanceRecord[]
  notifications        Notification[]
  assessmentShares     AssessmentShare[]    @relation("SharedWith")
  createdShares        AssessmentShare[]    @relation("SharedBy")
  auditLogs            AuditLog[]
  applications         ProgramApplication[]
  sharedDocuments      SharedDocument[]     @relation("SharedDocWith")
  createdDocuments     SharedDocument[]     @relation("SharedDocBy")
  topicProgress        TopicProgress[]
  teacherAttendances   TeacherAttendance[]
  announcementRecipients AnnouncementRecipient[]
  announcementsCreated Announcement[] @relation("AnnouncementCreator")
  createdAssessments     Assessment[] @relation("AssessmentCreator")
  studentOnboarding    StudentOnboarding?
  feedbackAuthored       Feedback[] @relation("FeedbackAuthor")
  feedbackAboutStudent   Feedback[] @relation("FeedbackAboutStudent")
  feedbackAboutTeacher   Feedback[] @relation("FeedbackAboutTeacher")
  feedbackReplies        Feedback[] @relation("FeedbackRepliedBy")
  assessmentAssignments  AssessmentAssignedStudent[] @relation("AssessmentAssignedStudents")
  programCalendarSlotsAsTeacher ProgramCalendarSlot[] @relation("ProgramCalendarSlotTeacher")
  portalGrantsReceived UserPortalGrant[] @relation("PortalGrantSubject")
  portalGrantsCreated  UserPortalGrant[] @relation("PortalGrantActor")
  programLessonCompletions ProgramLessonCompletion[]
  programCertificatesReceived ProgramCertificateSend[] @relation("ProgramCertStudent")
  programCertificatesSentBy   ProgramCertificateSend[] @relation("ProgramCertSentBy")
}

/** Extra portal access (Student / Teacher / Principal UI) beyond the user’s primary `User.role`. Managed in Principal → Settings. */
model UserPortalGrant {
  id          String   @id @default(cuid())
  userId      String
  portal      Role
  createdAt   DateTime @default(now())
  createdById String?

  user      User @relation("PortalGrantSubject", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User? @relation("PortalGrantActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([userId, portal])
  @@index([userId])
}

model Feedback {
  id             String             @id @default(cuid())
  authorId       String
  authorRole     FeedbackAuthorRole
  category       FeedbackCategory
  aboutStudentId String?
  aboutTeacherId String?
  title          String?
  message        String
  principalReply String?
  repliedAt      DateTime?
  repliedById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  author       User  @relation("FeedbackAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  aboutStudent User? @relation("FeedbackAboutStudent", fields: [aboutStudentId], references: [id], onDelete: SetNull)
  aboutTeacher User? @relation("FeedbackAboutTeacher", fields: [aboutTeacherId], references: [id], onDelete: SetNull)
  repliedBy    User? @relation("FeedbackRepliedBy", fields: [repliedById], references: [id], onDelete: SetNull)

  @@index([authorId])
  @@index([aboutStudentId])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Academic Structure ──────────────────────────────────────────────

model Program {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  durationYears Int    @default(1)
  durationText  String?
  programDomainId   String?
  programCategoryId String?
  programTypeId     String?
  isActive    Boolean  @default(true)
  /** Overrides InstitutionSettings when set (minimum % attendance required). */
  minAttendancePercent    Float?
  /** Minimum average score % across graded work (quizzes, tests, assignments, projects). */
  minAverageMarksPercent  Float?
  /** Minimum % of total program fees that must be paid to remain in good standing. */
  minFeePaidPercent       Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  programDomain   ProgramDomain?   @relation(fields: [programDomainId], references: [id], onDelete: SetNull)
  programCategory ProgramCategory? @relation(fields: [programCategoryId], references: [id], onDelete: SetNull)
  programType     ProgramType?     @relation(fields: [programTypeId], references: [id], onDelete: SetNull)

  batches     Batch[]
  subjects    Subject[]
  students    StudentProfile[]
  feeStructures FeeStructure[]
  applications  ProgramApplication[]
  teacherPrograms TeacherProgram[]
  announcements Announcement[]
  programCalendarSlots ProgramCalendarSlot[]
  programSyllabus       ProgramSyllabus?
  programCertificateSends ProgramCertificateSend[]

  @@index([programDomainId])
  @@index([programCategoryId])
  @@index([programTypeId])
}

/** Extended syllabus metadata and publish flag for Program Content (§18). */
model ProgramSyllabus {
  id           String   @id @default(cuid())
  programId    String   @unique
  instructions String?  @db.Text
  programHours String?
  feesNote     String?
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
}

/** Chapter under a Subject (program syllabus tree). */
model ProgramChapter {
  id                String   @id @default(cuid())
  subjectId         String
  title             String
  sortOrder         Int      @default(0)
  isMandatory       Boolean  @default(false)
  freePreviewLesson Boolean  @default(false)
  isPrerequisite    Boolean  @default(false)
  enableDiscussions Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  lessons ProgramLesson[]

  @@index([subjectId])
}

model ProgramLesson {
  id           String          @id @default(cuid())
  chapterId    String
  kind         ProgramLessonKind
  title        String
  sortOrder    Int             @default(0)
  content      Json?
  assessmentId String?
  isDraft      Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  chapter     ProgramChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  assessment  Assessment?    @relation("ProgramLessonAssessment", fields: [assessmentId], references: [id], onDelete: SetNull)
  completions ProgramLessonCompletion[]

  @@index([chapterId])
  @@index([assessmentId])
}

model ProgramLessonCompletion {
  id            String   @id @default(cuid())
  studentUserId String
  lessonId      String
  completedAt   DateTime @default(now())

  student User          @relation(fields: [studentUserId], references: [id], onDelete: Cascade)
  lesson  ProgramLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, lessonId])
  @@index([lessonId])
}

/** Program Content completion certificate emailed (separate from graduationCertificateSentAt). */
model ProgramCertificateSend {
  id            String   @id @default(cuid())
  programId     String
  studentUserId String
  sentAt        DateTime @default(now())
  sentByUserId  String

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  student User    @relation("ProgramCertStudent", fields: [studentUserId], references: [id], onDelete: Cascade)
  sentBy  User    @relation("ProgramCertSentBy", fields: [sentByUserId], references: [id])

  @@unique([programId, studentUserId])
  @@index([programId])
}

/** Master institutional branding and contact (singleton row id = 1). */
model InstitutionProfile {
  id Int @id @default(1)

  institutionNumber String?
  legalName         String?
  permanentAddress  String? @db.Text
  mailingAddress    String? @db.Text
  phone             String?
  email             String?
  website           String?
  socialFacebookUrl  String?
  socialLinkedInUrl  String?
  socialTwitterUrl   String?
  socialInstagramUrl String?
  logoUrl           String?
  brandColor        String?

  updatedAt DateTime @updatedAt
}

/** e.g. Software, Healthcare — configurable by principal. */
model ProgramDomain {
  id         String   @id @default(cuid())
  name       String
  /** Optional external reference ID for integrations; unique when set. */
  customerId String?  @unique
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programs     Program[]
  applications ProgramApplication[]
}

/** e.g. Vocational, Non-vocational. */
model ProgramCategory {
  id         String   @id @default(cuid())
  name       String
  customerId String?  @unique
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programs     Program[]
  applications ProgramApplication[]
}

/** e.g. Diploma, Post Graduate Diploma, Certificate, Short term. */
model ProgramType {
  id         String   @id @default(cuid())
  name       String
  customerId String?  @unique
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  programs     Program[]
  applications ProgramApplication[]
}

/** Single-row defaults for compliance thresholds (principal Settings). Programs may override per field. */
model InstitutionSettings {
  id Int @id @default(1)

  /** Minimum attendance % required (program default when Program.minAttendancePercent is null). */
  minAttendancePercent   Float @default(75)
  /** Minimum average marks % (quizzes, tests, assignments, projects). */
  minAverageMarksPercent Float @default(40)
  /** Minimum % of assigned fees that must be paid (student-wise; alerts when below). */
  minFeePaidPercent      Float @default(50)
  /** Optional: alert when total pending fees exceed this amount (same currency as fee structures). */
  pendingFeesAlertAmount Float?

  /** Public URL path to uploaded certificate template (e.g. /uploads/templates/...). */
  certificateTemplateUrl     String?
  certificateTemplateFileName String?
  transcriptTemplateUrl       String?
  transcriptTemplateFileName  String?
  /** Sample agreement PDF for students (onboarding step 1). */
  studentContractSampleUrl     String?
  studentContractSampleFileName String?

  updatedAt DateTime @updatedAt
}

model AcademicYear {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches   Batch[]
  holidays  Holiday[]
  announcements Announcement[]
}

model Batch {
  id             String       @id @default(cuid())
  name           String
  programId      String
  academicYearId String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  program        Program      @relation(fields: [programId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  students       StudentProfile[]
  teacherAssignments TeacherSubjectAssignment[]
  assessments    Assessment[]
  attendanceSessions AttendanceSession[]
  announcements Announcement[]
  programApplications ProgramApplication[]
  programCalendarSlots ProgramCalendarSlot[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  programId   String
  credits     Int      @default(3)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program  @relation(fields: [programId], references: [id])
  modules     Module[]
  teacherAssignments TeacherSubjectAssignment[]
  assessments Assessment[]
  attendanceSessions AttendanceSession[]
  programCalendarSlots ProgramCalendarSlot[]
  programChapters ProgramChapter[]
}

model Module {
  id                  String   @id @default(cuid())
  name                String
  description         String?
  orderIndex          Int      @default(0)
  subjectId           String
  isPublished         Boolean  @default(false)
  requiresCompletion  Boolean  @default(false)
  prerequisiteModuleId String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  subject             Subject  @relation(fields: [subjectId], references: [id])
  prerequisiteModule  Module?  @relation("ModulePrereq", fields: [prerequisiteModuleId], references: [id])
  dependentModules    Module[] @relation("ModulePrereq")
  topics              Topic[]
  assessments         Assessment[] @relation("ModuleAssessments")
}

model Topic {
  id          String   @id @default(cuid())
  name        String
  description String?
  orderIndex  Int      @default(0)
  moduleId    String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  contents    TopicContent[]
  assessments Assessment[] @relation("TopicAssessments")
  progress    TopicProgress[]
}

model TopicContent {
  id          String      @id @default(cuid())
  topicId     String
  title       String
  type        ContentType
  content     String?
  mediaUrl    String?
  fileSize    Int?
  duration    Int?
  orderIndex  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  topic       Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model TopicProgress {
  id          String   @id @default(cuid())
  topicId     String
  studentId   String
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  timeSpent   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topic       Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id])

  @@unique([topicId, studentId])
}

// ─── Profiles ────────────────────────────────────────────────────────

model StudentProfile {
  id             String        @id @default(cuid())
  userId         String        @unique
  enrollmentNo   String        @unique
  programId      String?
  batchId        String?
  status         StudentStatus @default(APPLIED)
  enrollmentDate DateTime?
  suspensionReason SuspensionReason?
  /** Principal note when cancelling or suspending (shown in notifications). */
  statusNote       String?
  /** Set when graduation certificate email was sent (avoids duplicate sends). */
  graduationCertificateSentAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  program        Program?      @relation(fields: [programId], references: [id])
  batch          Batch?        @relation(fields: [batchId], references: [id])
  feePayments    FeePayment[]
  submissionLogs StudentSubmissionLog[]
}

/** Post-enrollment checklist; created when a student is enrolled from an application. */
model StudentOnboarding {
  id                         String    @id @default(cuid())
  userId                     String    @unique
  contractAcknowledgedAt     DateTime?
  governmentIdsUploadedAt    DateTime?
  feeProofUploadedAt         DateTime?
  preAdmissionCompletedAt    DateTime?
  principalConfirmedAt       DateTime?
  contractDocumentUrl        String?
  /** Student-uploaded signed agreement (PDF or image). */
  signedContractUploadUrl    String?
  signedContractFileName     String?
  governmentIdUploadUrl        String?
  governmentIdFileName         String?
  feeProofUploadUrl            String?
  feeProofFileName             String?
  preAdmissionAssessmentId   String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TeacherProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  employeeId    String   @unique
  department    String?
  qualification String?
  specialization String?
  joinDate      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectAssignments TeacherSubjectAssignment[]
  teacherPrograms TeacherProgram[]
}

model TeacherProgram {
  id               String   @id @default(cuid())
  teacherProfileId String
  programId        String
  createdAt        DateTime @default(now())

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  program        Program        @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, programId])
}

model TeacherSubjectAssignment {
  id              String   @id @default(cuid())
  teacherProfileId String
  subjectId       String
  batchId         String
  createdAt       DateTime @default(now())

  teacherProfile  TeacherProfile @relation(fields: [teacherProfileId], references: [id])
  subject         Subject        @relation(fields: [subjectId], references: [id])
  batch           Batch          @relation(fields: [batchId], references: [id])

  @@unique([teacherProfileId, subjectId, batchId])
}

// ─── Fees ────────────────────────────────────────────────────────────

model FeeStructure {
  id          String   @id @default(cuid())
  programId   String
  name        String
  totalAmount Float
  dueDate     DateTime?
  term        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  program     Program  @relation(fields: [programId], references: [id])
  payments    FeePayment[]
}

model FeePayment {
  id               String    @id @default(cuid())
  studentProfileId String
  feeStructureId   String
  amountPaid       Float
  paymentDate      DateTime  @default(now())
  paymentMethod    String?
  transactionRef   String?
  notes            String?
  receiptUrl       String?
  receiptFileName  String?
  confirmedAt      DateTime?
  confirmedById    String?
  createdAt        DateTime  @default(now())

  studentProfile   StudentProfile @relation(fields: [studentProfileId], references: [id])
  feeStructure     FeeStructure   @relation(fields: [feeStructureId], references: [id])
  submissionLogs   StudentSubmissionLog[]
}

/** Append-only history for student uploads (onboarding docs + fee receipts) for audit trail in Pending Actions / Fees. */
model StudentSubmissionLog {
  id               String                @id @default(cuid())
  studentProfileId String
  kind             StudentSubmissionKind
  feePaymentId     String?
  fileUrl          String
  fileName         String
  amountPaid       Float?
  createdAt        DateTime              @default(now())

  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  feePayment     FeePayment?    @relation(fields: [feePaymentId], references: [id], onDelete: SetNull)

  @@index([studentProfileId, kind])
  @@index([feePaymentId])
}

enum StudentSubmissionKind {
  SIGNED_CONTRACT
  GOVERNMENT_ID
  ONBOARDING_FEE_PROOF
  FEE_RECEIPT
}

// ─── Assessments ─────────────────────────────────────────────────────

model Assessment {
  id               String           @id @default(cuid())
  title            String
  description      String?
  type             AssessmentType
  status           AssessmentStatus @default(DRAFT)
  subjectId        String
  batchId          String
  createdById      String
  moduleId         String?
  topicId          String?
  /** Free-form module label when not linking to a structured Module row. */
  moduleNameText   String?
  /** Free-form topic label when not linking to a structured Topic row. */
  topicNameText    String?
  isMandatory      Boolean          @default(false)
  totalMarks       Float
  passingMarks     Float?
  duration         Int?
  scheduledOpenAt  DateTime?
  scheduledCloseAt DateTime?
  resultsReleaseAt DateTime?
  assessmentDate   DateTime?
  linkToken        String           @unique @default(cuid())
  instructions     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  subject          Subject          @relation(fields: [subjectId], references: [id])
  batch            Batch            @relation(fields: [batchId], references: [id])
  creator          User             @relation("AssessmentCreator", fields: [createdById], references: [id])
  module           Module?          @relation("ModuleAssessments", fields: [moduleId], references: [id])
  topic            Topic?           @relation("TopicAssessments", fields: [topicId], references: [id])
  questions        Question[]
  attempts         Attempt[]
  shares           AssessmentShare[]
  scheduledEmails  ScheduledEmail[]
  /** When empty, any student in the batch may see the assessment (legacy). */
  assignedStudents AssessmentAssignedStudent[]
  programLessons   ProgramLesson[] @relation("ProgramLessonAssessment")
}

model AssessmentAssignedStudent {
  id            String   @id @default(cuid())
  assessmentId  String
  studentId     String
  createdAt     DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    User       @relation("AssessmentAssignedStudents", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
  @@index([studentId])
}

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  type          QuestionType
  questionText  String
  marks         Float
  orderIndex    Int          @default(0)
  correctAnswer String?
  rubric        String?
  maxLength     Int?
  mediaUrl      String?
  mediaType     String?
  additionalInfo String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options       QuestionOption[]
  answers       Answer[]
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  optionText  String
  isCorrect   Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())

  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ─── Submissions ─────────────────────────────────────────────────────

model Attempt {
  id            String        @id @default(cuid())
  assessmentId  String
  studentId     String
  status        AttemptStatus @default(IN_PROGRESS)
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  totalScore    Float?
  percentage    Float?
  feedback      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  assessment    Assessment    @relation(fields: [assessmentId], references: [id])
  student       User          @relation(fields: [studentId], references: [id])
  answers       Answer[]

  @@unique([assessmentId, studentId])
}

model Answer {
  id           String   @id @default(cuid())
  attemptId    String
  questionId   String
  studentId    String
  answerText   String?
  selectedOptionId String?
  autoScore    Float?
  manualScore  Float?
  feedback     String?
  isGraded     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attempt      Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id])
  student      User     @relation(fields: [studentId], references: [id])
}

// ─── Sharing ─────────────────────────────────────────────────────────

model AssessmentShare {
  id            String   @id @default(cuid())
  assessmentId  String
  sharedWithId  String
  sharedById    String
  canEdit       Boolean  @default(false)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())

  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  sharedWith    User       @relation("SharedWith", fields: [sharedWithId], references: [id])
  sharedBy      User       @relation("SharedBy", fields: [sharedById], references: [id])

  @@unique([assessmentId, sharedWithId])
}

// ─── Attendance ──────────────────────────────────────────────────────

model AttendanceSession {
  id              String    @id @default(cuid())
  subjectId       String
  batchId         String
  sessionDate     DateTime
  startTime       String?
  endTime         String?
  topic           String?
  overrideHoliday Boolean   @default(false)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subject         Subject   @relation(fields: [subjectId], references: [id])
  batch           Batch     @relation(fields: [batchId], references: [id])
  records         AttendanceRecord[]
  teacherAttendance TeacherAttendance?
}

model TeacherAttendance {
  id                    String           @id @default(cuid())
  attendanceSessionId   String           @unique
  teacherUserId         String
  status                AttendanceStatus @default(PRESENT)
  remarks               String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  session AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  teacher User              @relation(fields: [teacherUserId], references: [id])
}

model AttendanceRecord {
  id                  String           @id @default(cuid())
  attendanceSessionId String
  studentId           String
  status              AttendanceStatus @default(PRESENT)
  remarks             String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  session             AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student             User              @relation(fields: [studentId], references: [id])

  @@unique([attendanceSessionId, studentId])
}

model Holiday {
  id             String      @id @default(cuid())
  name           String
  date           DateTime
  type           HolidayType @default(PUBLIC)
  academicYearId String?
  region         String?
  createdAt      DateTime    @default(now())

  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])
}

/** Principal-configured time blocks on the Full Calendar (per program/batch/day, per teacher). */
model ProgramCalendarSlot {
  id            String                  @id @default(cuid())
  programId     String
  batchId       String
  teacherUserId String
  subjectId     String?
  slotDate      DateTime                @db.Date
  slotType        ProgramCalendarSlotType @default(SESSION)
  sessionCategory ProgramSessionCategory?
  startTime       String
  endTime         String
  colorHex        String                  @default("#6366f1")
  sortOrder     Int                     @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  batch   Batch   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  teacher User    @relation("ProgramCalendarSlotTeacher", fields: [teacherUserId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([batchId, slotDate])
  @@index([programId, batchId])
  @@index([teacherUserId])
}

// ─── Scheduling & Notifications ──────────────────────────────────────

model ScheduledEmail {
  id            String   @id @default(cuid())
  assessmentId  String?
  emailType     String
  recipientEmail String
  subject       String
  body          String?
  scheduledAt   DateTime
  sentAt        DateTime?
  isSent        Boolean  @default(false)
  createdAt     DateTime @default(now())

  assessment    Assessment? @relation(fields: [assessmentId], references: [id])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])
}

// ─── Program Applications ───────────────────────────────────────────

model ProgramApplication {
  id             String            @id @default(cuid())
  applicantId    String
  programId      String
  batchId        String?
  /** Snapshot from Program at submit time (domain / category / type). */
  programDomainId   String?
  programCategoryId String?
  programTypeId     String?
  status         ApplicationStatus @default(PENDING)
  personalStatement String?
  documents      String?
  reviewNotes    String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  applicant       User              @relation(fields: [applicantId], references: [id])
  program         Program           @relation(fields: [programId], references: [id])
  batch           Batch?            @relation(fields: [batchId], references: [id])
  programDomain   ProgramDomain?   @relation(fields: [programDomainId], references: [id], onDelete: SetNull)
  programCategory ProgramCategory? @relation(fields: [programCategoryId], references: [id], onDelete: SetNull)
  programType     ProgramType?     @relation(fields: [programTypeId], references: [id], onDelete: SetNull)

  @@index([programDomainId])
  @@index([programCategoryId])
  @@index([programTypeId])
}

// ─── Policies & Templates ───────────────────────────────────────────

model Policy {
  id          String     @id @default(cuid())
  title       String
  description String?
  content     String?
  fileUrl     String?
  category    String?
  policyType  PolicyType @default(OTHER)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SharedDocument {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        ContentType @default(DOCUMENT)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  category    String?
  sharedById  String
  isPublic    Boolean     @default(false)
  audienceRoles String[]  @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  sharedBy    User        @relation("SharedDocBy", fields: [sharedById], references: [id])
  sharedWith  User[]      @relation("SharedDocWith")
}

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  subject     String
  body        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id                     String   @id @default(cuid())
  title                  String
  body                   String
  createdById            String
  programId              String?
  batchId                String?
  academicYearId         String?
  recipientAll           Boolean  @default(true)
  /** When true, student recipients are emailed (default on publish). */
  sendEmail              Boolean  @default(true)
  /** When true, a copy was also sent to the creator (principal). */
  emailCopyToSender      Boolean  @default(false)
  /** Audience: all programs vs selected `programIds` (legacy `programId` still used for display on old rows). */
  allPrograms            Boolean  @default(true)
  allBatches             Boolean  @default(true)
  programIds             String[] @default([])
  batchIds               String[] @default([])
  allTeachers            Boolean  @default(false)
  teacherIds             String[] @default([])
  sendToStudents         Boolean  @default(true)
  sendToTeachers         Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  creator        User           @relation("AnnouncementCreator", fields: [createdById], references: [id])
  program        Program?       @relation(fields: [programId], references: [id])
  batch          Batch?         @relation(fields: [batchId], references: [id])
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id])
  recipients     AnnouncementRecipient[]
}

model AnnouncementRecipient {
  id              String   @id @default(cuid())
  announcementId  String
  userId          String
  emailSent       Boolean  @default(false)

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
}

// ─── Audit ───────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ─── Document Vault ─────────────────────────────────────────────────

enum FolderScope {
  GENERIC
  YEAR_SPECIFIC
  BATCH_SPECIFIC
}

model DocFolder {
  id              String      @id @default(cuid())
  name            String
  parentId        String?
  scope           FolderScope @default(GENERIC)
  yearId          String?
  programId       String?
  batchId         String?
  isAutoPopulated Boolean     @default(false)
  autoPopulateKey String?
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  parent   DocFolder?       @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children DocFolder[]      @relation("FolderTree")
  files    DocFile[]
  notes    InspectionNote[]

  @@index([parentId])
  @@index([yearId])
  @@index([programId, batchId])
}

model DocFile {
  id          String   @id @default(cuid())
  folderId    String
  fileName    String
  fileUrl     String
  fileSize    Int
  contentType String
  studentId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder DocFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}

model InspectionNote {
  id        String   @id @default(cuid())
  folderId  String
  note      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder DocFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
}
